# Firebase Configuration
# Get these from Firebase Console > Project Settings
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Google OAuth
# Get this from Google Cloud Console > APIs & Services > Credentials
# The OAuth client JSON file is saved in .secrets/google-oauth-client.json
GOOGLE_CLIENT_ID=

# Firebase Cloud Messaging (Push Notifications)
# Get from Firebase Console > Project Settings > Cloud Messaging
# This is the VAPID key for web push notifications
FCM_VAPID_KEY=

# Stripe Payment Gateway
# Get from https://dashboard.stripe.com/settings/keys
STRIPE_PUBLISHABLE_KEY=

# Google Maps API
# Get from https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=
