import React, { useState, useEffect } from 'react';
import { NavigationContainer, DefaultTheme, DarkTheme } from '@react-navigation/native';
import { createNativeStackNavigator } from '@react-navigation/native-stack';
import { useColorScheme, View, Text, ActivityIndicator, StyleSheet } from 'react-native';
import LoginScreen from './screens/auth/LoginScreen';
import HomeCustomerScreen from './screens/customer/HomeCustomerScreen';
import DashboardOwnerScreen from './screens/owner/DashboardOwnerScreen';
import OwnerPaywallScreen from './screens/owner/OwnerPaywallScreen';
import OwnerSetupScreen from './screens/owner/OwnerSetupScreen';
import StaffAreaScreen from './screens/staff/StaffAreaScreen';
import BookingScreen from './screens/appointments/BookingScreen';

export type RootStackParamList = {
  Login: undefined;
  CustomerHome: undefined;
  OwnerDashboard: undefined;
  StaffArea: undefined;
  OwnerPaywall: undefined;
  OwnerSetup: undefined;
  Booking: undefined;
};

const Stack = createNativeStackNavigator<RootStackParamList>();

function SplashScreen({ onFinish }: { onFinish: () => void }) {
  useEffect(() => {
    // Timeout de 3 segundos para inicialização
    const timer = setTimeout(() => {
      console.log('✅ App inicializado (modo demo)');
      onFinish();
    }, 1500);
    return () => clearTimeout(timer);
  }, []);

  return (
    <View style={styles.splash}>
      <Text style={styles.logo}>💈 BARBERPRO</Text>
      <ActivityIndicator size="large" color="#22c55e" style={{ marginTop: 20 }} />
      <Text style={styles.subtitle}>Carregando...</Text>
      <Text style={styles.demo}>Modo Demo</Text>
    </View>
  );
}

export default function App() {
  const scheme = useColorScheme();
  const [isReady, setIsReady] = useState(false);

  if (!isReady) {
    return <SplashScreen onFinish={() => setIsReady(true)} />;
  }

  return (
    <NavigationContainer theme={scheme === 'dark' ? DarkTheme : DefaultTheme}>
      <Stack.Navigator screenOptions={{ headerShown: false }}>
        <Stack.Screen name="Login" component={LoginScreen} />
        <Stack.Screen name="CustomerHome" component={HomeCustomerScreen} />
        <Stack.Screen name="OwnerDashboard" component={DashboardOwnerScreen} />
        <Stack.Screen name="OwnerPaywall" component={OwnerPaywallScreen} />
        <Stack.Screen name="OwnerSetup" component={OwnerSetupScreen} />
        <Stack.Screen name="StaffArea" component={StaffAreaScreen} />
        <Stack.Screen name="Booking" component={BookingScreen} />
      </Stack.Navigator>
    </NavigationContainer>
  );
}

const styles = StyleSheet.create({
  splash: {
    flex: 1,
    backgroundColor: '#0b1220',
    alignItems: 'center',
    justifyContent: 'center',
    padding: 20,
  },
  logo: {
    fontSize: 48,
    fontWeight: 'bold',
    color: '#22c55e',
    marginBottom: 10,
  },
  subtitle: {
    fontSize: 18,
    color: '#94a3b8',
    marginTop: 20,
  },
  demo: {
    fontSize: 14,
    color: '#64748b',
    marginTop: 40,
    fontStyle: 'italic',
  },
});
